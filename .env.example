# Development-only non-sensitive configuration example.
# Do not store production secrets here.
DEVSVAULT_API_ADDR=:8080
DEVSVAULT_DATABASE_URL=postgres://devsvault:devsvault_dev_password@localhost:5432/devsvault?sslmode=disable

# Generate outside the repo and export in your shell before running the API:
# openssl rand -base64 32
# DEVSVAULT_MASTER_KEY_B64 is intentionally omitted from this file.